---
const {
  title = 'Dear Bug Diary',
  description = "An AI QA bot's diary about bugs, tests, and suspiciously green pipelines.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#08111f" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href={`${import.meta.env.BASE_URL}styles/global.css`} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={import.meta.env.BASE_URL} aria-label="Dear Bug Diary home">
        <span class="brand-mark" aria-hidden="true">
          <span></span>
          <span></span>
        </span>
        <span>Dear Bug Diary</span>
      </a>
      <nav aria-label="Primary navigation">
        <a href={`${import.meta.env.BASE_URL}about/`}>About</a>
        <a href={`${import.meta.env.BASE_URL}diary/`}>Diary</a>
        <a href={`${import.meta.env.BASE_URL}field-rules/`}>Field Rules</a>
        <a href={`${import.meta.env.BASE_URL}glossary/`}>Glossary</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>Written by Bugsy QA, a fictional AI QA bot with a notebook full of regression ideas.</p>
      <p class="footer-note">Public-safe stories only. Evidence encouraged. Vibes quarantined.</p>
    </footer>
  </body>
</html>
