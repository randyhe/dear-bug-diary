---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Bugsy QA reporting from the test bench</p>
      <h1>Dear Bug Diary</h1>
      <p>
        An AI QA bot's diary about bugs, tests, human review, and suspiciously
        green pipelines.
      </p>
      <p>
        A public-safe portfolio of AI-assisted QA, testing, evidence, and
        governance work. The diary format turns real QA progress into a readable
        story while the Progress page tracks the buildout of IQDP, an
        Intelligent Quality & Delivery Platform.
      </p>
      <div class="hero-actions" aria-label="Primary actions">
        <a class="button-link" href={`${import.meta.env.BASE_URL}progress/`}>
          Explore IQDP progress
        </a>
        <a class="text-link" href={`${import.meta.env.BASE_URL}diary/`}>
          Read the diary
        </a>
      </div>
    </div>
    <aside class="bugsy-console" aria-label="Bugsy QA status note">
      <div class="console-top">
        <span class="status-light"></span>
        <strong>Bugsy QA</strong>
        <span>online</span>
      </div>
      <dl>
        <div>
          <dt>Current focus</dt>
          <dd>Evidence-first QA workflows</dd>
        </div>
        <div>
          <dt>Favorite artifact</dt>
          <dd>Reusable regression evidence</dd>
        </div>
        <div>
          <dt>Active context</dt>
          <dd>AI-assisted review, reporting, and governance</dd>
        </div>
      </dl>
    </aside>
  </section>

  <section class="home-focus" aria-label="Featured site paths">
    <article class="feature-strip">
      <p class="eyebrow">Build progress</p>
      <h2>Building IQDP as an AI-assisted QA operating model.</h2>
      <p>
        Review the capability map, maturity board, phase timeline, and next
        direction behind the public diary entries.
      </p>
      <a class="text-link" href={`${import.meta.env.BASE_URL}progress/`}>
        Review the progress page
      </a>
    </article>

    <article class="feature-strip secondary-feature">
      <p class="eyebrow">Latest published entry</p>
      <h2>2026-06-27: The listener learned to restart</h2>
      <p>
        A fictional operations note about resilient test workers, restarts,
        recordings, and why test infrastructure deserves its own evidence.
      </p>
      <a class="text-link" href={`${import.meta.env.BASE_URL}diary/2026-06-27-the-listener-learned-to-restart/`}>
        Read the entry
      </a>
    </article>
  </section>

  <section class="link-grid" aria-label="Site sections">
    <a class="card" href={`${import.meta.env.BASE_URL}progress/`}>
      <strong>Progress</strong>
      <span>Review the IQDP capability map, phase timeline, and next direction.</span>
    </a>
    <a class="card" href={`${import.meta.env.BASE_URL}diary/`}>
      <strong>Diary</strong>
      <span>Read fictional notes wrapped around public-safe QA progress notes.</span>
    </a>
    <a class="card" href={`${import.meta.env.BASE_URL}field-rules/`}>
      <strong>Field Rules</strong>
      <span>Small QA rules Bugsy keeps taped to the inside of its dashboard.</span>
    </a>
    <a class="card" href={`${import.meta.env.BASE_URL}about/`}>
      <strong>About</strong>
      <span>Meet Bugsy, the public-safe diary format, and the glossary of QA terms.</span>
    </a>
  </section>
</BaseLayout>
