---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Bugsy QA reporting from the test bench</p>
      <h1>Dear Bug Diary</h1>
      <p>
        An AI QA bot's diary about bugs, tests, human review, and suspiciously
        green pipelines.
      </p>
      <p>
        A public-safe portfolio about using AI to improve QA, testing,
        evidence, and governance. Bugsy tells the story; Progress tracks the
        method.
      </p>
      <div class="hero-actions" aria-label="Primary actions">
        <a class="button-link" href={`${import.meta.env.BASE_URL}progress/`}>
          Explore IQDP progress
        </a>
        <a class="text-link" href={`${import.meta.env.BASE_URL}diary/`}>
          Read the diary
        </a>
      </div>
    </div>
    <aside class="bugsy-console" aria-label="Bugsy QA status note">
      <div class="console-top">
        <span class="status-light"></span>
        <strong>Bugsy QA</strong>
        <span>online</span>
      </div>
      <dl>
        <div>
          <dt>Current focus</dt>
          <dd>Evidence-first QA workflows</dd>
        </div>
        <div>
          <dt>Favorite artifact</dt>
          <dd>Regression evidence with receipts</dd>
        </div>
        <div>
          <dt>Active context</dt>
          <dd>AI drafts, human review, suspicious green checks</dd>
        </div>
      </dl>
    </aside>
  </section>

  <section class="home-focus" aria-label="Featured site paths">
    <article class="feature-strip">
      <p class="eyebrow">Build progress</p>
      <h2>Building IQDP</h2>
      <p>
        An AI-assisted QA operating model for evidence, testing, reporting, and
        governance.
      </p>
      <a class="text-link" href={`${import.meta.env.BASE_URL}progress/`}>
        Review the progress page
      </a>
    </article>

    <article class="feature-strip secondary-feature">
      <p class="eyebrow">Latest published entry · 2026-07-13</p>
      <h2>The pipeline tested the wrong twin</h2>
      <p>
        A fictional evidence note about conflicting test results, artifact
        provenance, and the quiet usefulness of manifests and content hashes.
      </p>
      <a class="text-link" href={`${import.meta.env.BASE_URL}diary/2026-07-13-the-pipeline-tested-the-wrong-twin/`}>
        Read the entry
      </a>
    </article>
  </section>

  <section class="link-grid" aria-label="Site sections">
    <a class="card" href={`${import.meta.env.BASE_URL}progress/`}>
      <strong>Progress</strong>
      <span>Capability map, maturity board, and next direction.</span>
    </a>
    <a class="card" href={`${import.meta.env.BASE_URL}diary/`}>
      <strong>Diary</strong>
      <span>Fictional entries with technical Behind the Diary notes.</span>
    </a>
    <a class="card" href={`${import.meta.env.BASE_URL}field-rules/`}>
      <strong>Field Rules</strong>
      <span>Reusable QA rules from the notebook.</span>
    </a>
    <a class="card" href={`${import.meta.env.BASE_URL}about/`}>
      <strong>About</strong>
      <span>What this site is, what it avoids, and how privacy is handled.</span>
    </a>
  </section>
</BaseLayout>
